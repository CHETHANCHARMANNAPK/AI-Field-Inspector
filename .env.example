# ────────────────────────────────────────────────────────────
# AI Field Inspector — Environment Configuration
# Copy this file to .env and fill in your API keys.
# ────────────────────────────────────────────────────────────

# LLM Provider: "openai" or "gemini"
LLM_PROVIDER=gemini

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=

# YOLO model weights (auto-downloads yolov8n if not present)
YOLO_MODEL_PATH=models/yolov8n.pt

# Upload directory for images and PDFs
UPLOAD_DIR=uploads
